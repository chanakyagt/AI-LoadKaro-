# Supabase (Expo exposes only vars prefixed with EXPO_PUBLIC_)
# Copy this file to `.env` and paste your project URL and anon key from:
# Supabase Dashboard → Project Settings → API

EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
# Optional alias (if you name the anon key this in the dashboard export):
# EXPO_PUBLIC_SUPABASE_KEY=
